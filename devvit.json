{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "bubblesneverlie",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html",
        "height": "tall",
        "inline": true
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "menu": {
    "items": [
      {
        "label": "Bubbles Never Lie: New Post",
        "description": "Chart subreddit activity with a fun bubble chart!",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-post"
      }
    ]
  },
  "forms": {
    "createPostForm": "/internal/form/create-post-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "refreshPostCache": {
        "endpoint": "/internal/cache/refresh-post-cache",
        "cron": "* * * * *"
      },
      "refreshCommentCache": {
        "endpoint": "/internal/cache/refresh-comment-cache",
        "cron": "0 * * * *"
      },
      "refreshCommentCacheQueue": {
        "endpoint": "/internal/cache/refresh-comment-cache-queue",
        "cron": "* * * * *"
      },
      "refreshContributorCache": {
        "endpoint": "/internal/cache/refresh-contributor-cache",
        "cron": "*/30 * * * *"
      },
      "refreshSubredditIcons": {
        "endpoint": "/internal/cache/refresh-subreddit-icons",
        "cron": "0 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "bubblesneverlie_dev"
  }
}
