{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "bubblesneverlie",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html",
        "height": "tall",
        "inline": true
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "menu": {
    "items": [
      {
        "label": "Bubbles Never Lie: New Post",
        "description": "Chart subreddit activity with a fun bubble chart!",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-post"
      }
    ]
  },
  "forms": {
    "createPostForm": "/internal/form/create-post-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostCreate": "/internal/triggers/on-post-create",
    "onCommentCreate": "/internal/triggers/on-comment-create"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "bubblesneverlie_dev"
  }
}
