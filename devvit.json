{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "bubble-stats",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "game.html",
        "height": "tall",
        "inline": true
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator"
    }
  },
  "menu": {
    "items": [
      {
        "label": "Create bubble stats post",
        "description": "Chart subreddit posts and comments by activity",
        "location": "subreddit",
        "forUserType": "user",
        "endpoint": "/internal/menu/create-chart"
      }
    ]
  },
  "forms": {
    "timeframeForm": "/internal/form/create-chart-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/cache/refresh-app-cache",
    "onAppUpgrade": "/internal/cache/refresh-app-cache"
  },
  "scheduler": {
    "tasks": {
      "refreshPostCache": {
        "endpoint": "/internal/cache/refresh-post-cache",
        "cron": "* * * * *"
      },
      "refreshCommentCache": {
        "endpoint": "/internal/cache/refresh-comment-cache",
        "cron": "0 * * * *"
      },
      "refreshSubredditIcons": {
        "endpoint": "/internal/cache/refresh-subreddit-icons",
        "cron": "0 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "bubble_stats_dev"
  }
}
